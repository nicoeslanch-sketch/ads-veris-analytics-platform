# ── Variables PÚBLICAS del frontend (Vite las expone en el bundle) ──
# Copia este archivo como `.env` y completa con los valores de tu proyecto.
# NUNCA pongas aquí claves secretas (service_role, Anthropic, etc.).

# URL de tu proyecto Supabase (Dashboard → Settings → API)
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Clave anónima (anon/public) de Supabase — es pública por diseño, protegida por RLS
VITE_SUPABASE_ANON_KEY=eyJ...

# URL base del motor de datos Python (FastAPI). En local: http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000

# ── Fase 7/8 ──
# Interruptor del gating por plan en la UI (candados de Limpieza dirigida y
# descarga de la base limpia). Desde la Fase 8 el DEFAULT es true; el aviso
# "Necesitas el Plan X" lleva directo a Planes. Para apagarlo en pruebas:
# VITE_PLAN_ENFORCEMENT=false (+ PLAN_ENFORCEMENT=false en el backend).
VITE_PLAN_ENFORCEMENT=true
