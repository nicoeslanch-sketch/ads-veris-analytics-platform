# ── Variables SECRETAS del backend (motor de datos FastAPI) ──
# Copia este archivo como `.env` y completa. NUNCA subir el `.env` al repo
# y NUNCA usar estas claves en el frontend React/Vite.

# Supabase (Dashboard → Settings → API)
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...          # clave service_role — SOLO backend
SUPABASE_JWT_SECRET=super-secret-jwt...   # Settings → API → JWT Secret (valida tokens de usuarios)
SUPABASE_STORAGE_BUCKET=datasets          # bucket privado donde el frontend sube los archivos

# Anthropic (Claude) — SOLO backend, jamás en el navegador
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001 # rápido y barato para el MVP
# ANTHROPIC_MODEL=claude-opus-4-8         # alternativa premium (más caro)

# Cuotas mensuales de consultas IA (insights) por plan (requiere migración 0006)
AI_MONTHLY_LIMIT_BASICO=20
AI_MONTHLY_LIMIT_ANALISTA=200
AI_MONTHLY_LIMIT_GOLD=200

# ── Fase 7/8: planes y limpieza dirigida ──
# Interruptor global del gating por plan. Desde la Fase 8 el DEFAULT es true:
# descargar la base limpia y la limpieza dirigida exigen Plan Analista, y el
# administrador (profiles.is_admin) pasa todas las puertas. Para apagarlo en
# pruebas: PLAN_ENFORCEMENT=false (+ VITE_PLAN_ENFORCEMENT=false en frontend).
PLAN_ENFORCEMENT=true
# Intentos base de limpieza dirigida por mes, POR PLAN (los tokens addon se
# suman; requiere migración 0009)
AI_CLEANING_MONTHLY_LIMIT=10        # Plan Analista
AI_CLEANING_MONTHLY_LIMIT_GOLD=25   # Plan Gold
# Costura IA del motor (§5.13): refinado final del dataset. Preparada pero
# APAGADA hasta perfeccionar el análisis determinista de la plataforma.
AI_REFINE_ENABLED=false
# Fase 9: clasificador IA de columnas sin match en el diccionario de palabras
# clave (api/app/data/palabras_clave_roles.csv). Preparado pero APAGADO.
AI_CLASSIFIER_ENABLED=false

# ── Fase 8: retención de archivos en Storage (por usuario) ──
# Tope de archivos guardados según plan; lo no usado hace más de
# STORAGE_RETENTION_DAYS días se purga, conservando SIEMPRE los últimos
# STORAGE_KEEP_LAST. Se ejecuta al subir un archivo (POST /storage/retention).
STORAGE_MAX_FILES_BASICO=10
STORAGE_MAX_FILES_ANALISTA=25
STORAGE_MAX_FILES_GOLD=50
STORAGE_RETENTION_DAYS=60
STORAGE_KEEP_LAST=5

# CORS: orígenes permitidos, separados por coma
ALLOWED_ORIGINS=http://localhost:5173,https://TU-APP.vercel.app

# SOLO desarrollo local sin Supabase: acepta requests sin JWT (nunca en producción)
DEV_AUTH_BYPASS=false
