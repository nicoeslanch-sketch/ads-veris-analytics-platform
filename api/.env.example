# ── Variables SECRETAS del backend (motor de datos FastAPI) ──
# Copia este archivo como `.env` y completa. NUNCA subir el `.env` al repo
# y NUNCA usar estas claves en el frontend React/Vite.

# Supabase (Dashboard → Settings → API)
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...          # clave service_role — SOLO backend
SUPABASE_JWT_SECRET=super-secret-jwt...   # Settings → API → JWT Secret (valida tokens de usuarios)
SUPABASE_STORAGE_BUCKET=datasets          # bucket privado donde el frontend sube los archivos

# Anthropic (Claude) — SOLO backend, jamás en el navegador
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8           # configurable; no hardcodear en código

# CORS: orígenes permitidos, separados por coma
ALLOWED_ORIGINS=http://localhost:5173,https://TU-APP.vercel.app

# SOLO desarrollo local sin Supabase: acepta requests sin JWT (nunca en producción)
DEV_AUTH_BYPASS=false
